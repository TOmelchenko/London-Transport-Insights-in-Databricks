   "source": [
    "USE workspace.london_transport;\n",
    "\n",
    "-- Total passengers journey by line\n",
    "SELECT \n",
    "      coalesce(line_name, 'Unknown') AS line,\n",
    "      sum(passenger_count) AS total_passengers\n",
    "FROM transport_activity\n",
    "GROUP BY line_name\n",
    "ORDER BY total_passengers DESC;\n",
    "\n"
   ]
  }
 ],
